# Fichiers TEMPLATE — fetches depuis GitHub a chaque /init-project
# Ne pas modifier manuellement, ils seront ecrases lors de la prochaine sync
#
# IMPORTANT : Ce fichier est copie par /init-project en tant que .gitignore
# a la racine du projet cible. Il n'est PAS actif dans le template repo lui-meme.

# Repertoire source du template (fetch depuis GitHub)
TEMPLATE_claude/

# Commandes template générées depuis TEMPLATE_claude/ (*.md — jamais éditées manuellement)
# Les commandes sont directement invocables comme /xxx — pas de fichier compagnon projet
.claude/commands/*.md
.claude/commands/*.template.md

# Agents template générés depuis TEMPLATE_claude/ (*.template.md — jamais édités manuellement)
# Les *.md dans agents/ (hors dev-*) sont des adaptations projet — trackés dans git
.claude/agents/*.template.md
.claude/agents/context/

# Fichiers PROJET — toujours git trackes (ne pas ajouter ici)
# .claude/CLAUDE.md
# .claude/project-config.json
# .claude/memory/
# .claude/agents/dev-backend.md
# .claude/agents/dev-frontend.md
# .claude/agents/dev-firmware.md

# Dossier de travail inter-agents (rapports et handoffs temporaires)
_work/
